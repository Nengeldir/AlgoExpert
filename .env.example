# Backend
DATABASE_PATH=./data/app.db
JWT_SECRET=change-me-in-production-use-a-long-random-string
ADMIN_TOKEN=change-me-admin-token
PORT=3000
CORS_ORIGIN=http://localhost:5173

# YouTube Data API v3 key — required for /admin/youtube/suggest
# Get one at https://console.cloud.google.com/ → APIs & Services → Credentials
YOUTUBE_API_KEY=CHANGE-ME-YOUTUBE-API-KEY

# Resend API key — required in production to send password-reset emails.
# If unset, reset links are logged to the backend console instead (fine for local dev).
# Get one at https://resend.com/api-keys
RESEND_API_KEY=example-api-key
EMAIL_FROM=Expert Vote <onboarding@resend.dev>

# Frontend (Vite exposes vars prefixed VITE_)
VITE_API_URL=http://localhost:3000
